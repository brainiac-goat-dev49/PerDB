{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A PerDB project containing database collections and configuration.",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string", "description": "The UID of the project owner." },
        "name": { "type": "string", "description": "The name of the project." },
        "apiKey": { "type": "string", "description": "The public API key for the project." },
        "secretKey": { "type": "string", "description": "The secret key for the project." },
        "rules": { "type": "string", "description": "JSON string of security rules for the project collections." },
        "collectionList": { "type": "array", "items": { "type": "string" }, "description": "List of collection names in this project." },
        "stats": {
          "type": "object",
          "properties": {
            "reads": { "type": "number" },
            "writes": { "type": "number" },
            "activeUsers": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "name", "apiKey"]
    },
    "User": {
      "title": "User",
      "description": "A PerDB user profile.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "isBanned": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      }
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback or contact messages.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "BannedEmail": {
      "title": "BannedEmail",
      "description": "A record of a banned email address.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "bannedAt": { "type": "string", "format": "date-time" },
        "reason": { "type": "string" }
      }
    }
  },
  "firestore": {
    "projects": {
      "schema": "Project",
      "description": "Collection of PerDB projects."
    },
    "users": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "feedback": {
      "schema": "Feedback",
      "description": "Collection of feedback messages."
    },
    "banned_emails": {
      "schema": "BannedEmail",
      "description": "Collection of banned email addresses."
    }
  }
}
